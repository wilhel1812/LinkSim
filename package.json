  },
  "dependencies": {
    "@clerk/react": "^6.1.0",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "fflate": "^0.8.2",
    "jose": "^6.2.1",
    "maplibre-gl": "^5.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0",
