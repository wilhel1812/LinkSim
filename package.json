{
  "name": "linksim",
  "private": true,
  "version": "0.15.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "build:meta": "node scripts/generate-build-info.mjs",
    "peaks:build": "node scripts/build-open-peak-index.mjs",
    "build:verify": "node scripts/verify-build-info.mjs",
    "dev": "vite --config config/vite.config.ts",
    "build:client": "npm run build:meta && vite build --config config/vite.config.ts",
    "build:bundle": "npm run build:meta && tsc -b config/tsconfig.json && vite build --config config/vite.config.ts",
    "dev:edge": "npm run build:client && npx wrangler pages dev dist --d1 DB=linksim --r2 AVATAR_BUCKET=linksim-avatars --binding ALLOW_INSECURE_DEV_AUTH=true --binding DEV_AUTH_USER_ID=local-dev-user --binding ADMIN_USER_IDS=local-dev-user --local --persist-to .wrangler/state",
    "build": "npm run build:meta && npm run build:bundle",
    "lint": "eslint .",
    "security:scan": "node scripts/security-scan.mjs",
    "preview": "vite preview --config config/vite.config.ts",
    "test": "vitest run --config config/vitest.config.ts",
    "test:ci": "vitest run --coverage --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "smoke:edge": "node scripts/scripts_pw_check.mjs",
    "smoke:pw": "node scripts/scripts_pw_check.mjs",
    "smoke:scenario": "node scripts/scripts_smoke_scenario.mjs",
    "smoke:profile": "node scripts/scripts_smoke_profile_only.mjs",
    "smoke:fit-profile": "node scripts/scripts_smoke_fit_profile.mjs",
    "smoke:itm": "node scripts/scripts_smoke_itm.mjs",
    "deploy:staging": "npm run build:bundle && npm run build:verify && node scripts/deploy-pages-safe.mjs --target staging",
    "deploy:staging:preview": "npm run build:bundle && npm run build:verify && node scripts/deploy-pages-safe.mjs --target staging-preview",
    "deploy:prod:main": "npm run build:bundle && npm run build:verify && node scripts/deploy-pages-safe.mjs --target prod-main",
    "release:prod": "node scripts/release-prod.mjs",
    "refresh:staging:d1": "./scripts/refresh-staging-d1.sh",
    "refresh:staging:r2": "./scripts/refresh-staging-r2.sh",
    "refresh:staging": "npm run refresh:staging:d1 && npm run refresh:staging:r2",
    "refresh-and-deploy:staging": "npm run refresh:staging && npm run deploy:staging",
    "tf:bootstrap:state": "infra/terraform/scripts/bootstrap-state-backend.sh",
    "tf:fmt": "infra/terraform/scripts/fmt-check.sh",
    "tf:validate": "infra/terraform/scripts/validate.sh",
    "tf:init:staging": "infra/terraform/scripts/init.sh staging",
    "tf:init:prod": "infra/terraform/scripts/init.sh prod",
    "tf:init:staging:local": "infra/terraform/scripts/init.sh staging --backend=false",
    "tf:init:prod:local": "infra/terraform/scripts/init.sh prod --backend=false",
    "tf:import:staging": "infra/terraform/scripts/import.sh staging",
    "tf:import:prod": "infra/terraform/scripts/import.sh prod",
    "tf:plan:staging": "infra/terraform/scripts/plan.sh staging",
    "tf:plan:prod": "infra/terraform/scripts/plan.sh prod",
    "tf:discover:staging": "node infra/terraform/scripts/discover-cloudflare.mjs staging infra/terraform/environments/staging/discovery.json",
    "tf:discover:prod": "node infra/terraform/scripts/discover-cloudflare.mjs prod infra/terraform/environments/prod/discovery.json"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "fflate": "^0.8.2",
    "geotiff": "^3.0.5",
    "jose": "^6.2.1",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.14.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.73.0"
  }
}
